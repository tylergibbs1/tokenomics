# tokenomics configuration — all optional. Copy to .env and adjust as needed.
# No API key is required: the OpenRouter /models endpoint is public.

# OpenRouter Models API endpoint (override only if you proxy it).
# OPENROUTER_API_URL=https://openrouter.ai/api/v1/models

# Seconds to reuse a fetched model list within one process (default 60).
# Data stays at most this old. Set 0 to fetch fresh on every single call.
# TOKENOMICS_CACHE_TTL_SECONDS=60

# Hard timeout (ms) for the OpenRouter request, so a hung network fails fast (default 15000).
# TOKENOMICS_FETCH_TIMEOUT_MS=15000

# get_model_pricing miss behavior. Default (unset/false): return matched:false with
# candidates (agent-friendly). Set to 1/true for a hard MODEL_NOT_FOUND error instead.
# TOKENOMICS_STRICT_LOOKUP=0
